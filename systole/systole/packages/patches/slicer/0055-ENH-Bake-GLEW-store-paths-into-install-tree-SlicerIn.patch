From 6603fa8698cef8a45381237280210d47897f34ab Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Sun, 1 Mar 2026 19:59:30 +0100
Subject: [PATCH] ENH: Bake GLEW store paths into install-tree
 SlicerInstallConfig

When building Slicer extensions against an installed Slicer (Guix store),
UseSlicer.cmake triggers find_package(ITK) which loads ITKVtkGlue and
then calls find_package(VTK), which in turn runs VTK's FindGLEW.cmake.
That module uses find_path/find_library and fails because GLEW is not
in the guix shell profile.

Pre-set GLEW_LIBRARY and GLEW_INCLUDE_DIR as CACHE variables in the
install-tree SlicerConfig.cmake (baked at Slicer build time via @...@
substitution) so VTK's FindGLEW.cmake uses the pre-set cache values
instead of searching, consistent with how HDF5_LIBRARIES/INCLUDE_DIRS
are already handled.
---
 CMake/SlicerInstallConfig.cmake.in | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/CMake/SlicerInstallConfig.cmake.in b/CMake/SlicerInstallConfig.cmake.in
index 08c1a22d24..34ec6aa430 100644
--- a/CMake/SlicerInstallConfig.cmake.in
+++ b/CMake/SlicerInstallConfig.cmake.in
@@ -63,6 +63,8 @@ if(NOT Slicer_SUPERBUILD)
   set(ITK_DIR "@ITK_DIR@")
   set(HDF5_LIBRARIES "@HDF5_LIBRARIES@")
   set(HDF5_INCLUDE_DIRS "@HDF5_INCLUDE_DIRS@")
+  set(GLEW_LIBRARY "@GLEW_LIBRARY@" CACHE FILEPATH "GLEW library" FORCE)
+  set(GLEW_INCLUDE_DIR "@GLEW_INCLUDE_DIR@" CACHE PATH "GLEW include directory" FORCE)
   set(vtkAddon_DIR "@vtkAddon_DIR@")
   if(Slicer_USE_TBB)
     set(TBB_DIR "@TBB_DIR@")
