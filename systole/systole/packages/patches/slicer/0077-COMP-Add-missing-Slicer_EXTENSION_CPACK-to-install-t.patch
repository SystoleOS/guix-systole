From 63fed9682bb32d3d6b7bc25b4db22860aa1e82af Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 5 Mar 2026 19:38:23 +0100
Subject: [PATCH] COMP: Add missing Slicer_EXTENSION_CPACK to install-tree
 SlicerConfig

SlicerExtensionCPack.cmake is installed to lib/Slicer-5.8/CMake/ but
Slicer_EXTENSION_CPACK was never set in SlicerInstallConfig.cmake.in.
Extension CMakeLists.txt files call include(${Slicer_EXTENSION_CPACK})
unconditionally; with the variable unset the path is empty, causing an
'include() only takes one file' error (surfaced as a wrong-number-of-
arguments failure in the include() macro override from
UseSlicerExecutionModel.cmake).
---
 CMake/SlicerInstallConfig.cmake.in | 1 +
 1 file changed, 1 insertion(+)

diff --git a/CMake/SlicerInstallConfig.cmake.in b/CMake/SlicerInstallConfig.cmake.in
index 78ee741ec2..841f87f709 100644
--- a/CMake/SlicerInstallConfig.cmake.in
+++ b/CMake/SlicerInstallConfig.cmake.in
@@ -226,6 +226,7 @@ endif()
 
 # Extension build support (required when building extensions against an installed Slicer)
 set(Slicer_EXTENSION_GENERATE_CONFIG "${Slicer_CMAKE_DIR}/SlicerExtensionGenerateConfig.cmake")
+set(Slicer_EXTENSION_CPACK "${Slicer_CMAKE_DIR}/SlicerExtensionCPack.cmake")
 
 # Launch command used by SlicerMacroSimpleTest and SlicerMacroBuildLoadableModule
 # when defining CTest tests.  Replaces the CTK applauncher (absent in Guix):
-- 
2.52.0

