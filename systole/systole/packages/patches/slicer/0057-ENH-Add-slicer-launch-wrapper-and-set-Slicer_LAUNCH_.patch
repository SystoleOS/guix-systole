From 27ee30ee2d7d7e05a6d1a1095c981f2b06b369b4 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Mon, 2 Mar 2026 09:54:29 +0100
Subject: [PATCH] ENH: Add slicer-launch wrapper and set Slicer_LAUNCH_COMMAND
 for extension tests

Without CTK applauncher (Slicer_USE_CTKAPPLAUNCHER=OFF in Guix), the
install-tree SlicerConfig.cmake left Slicer_LAUNCH_COMMAND empty, causing
SlicerMacroSimpleTest and the generic CXX module test infrastructure to fail
with 'Slicer_LAUNCH_COMMAND variable is not set'.

Set Slicer_LAUNCH_COMMAND and SEM_LAUNCH_COMMAND to bin/slicer-launch in
SlicerInstallConfig.cmake.in.  The slicer-launch script is installed by a new
Guix build phase: it reads SLICER_ADDITIONAL_MODULE_PATHS, prepends each entry
to LD_LIBRARY_PATH, and execs its arguments.  Before running ctest on an
extension build, the developer exports SLICER_ADDITIONAL_MODULE_PATHS to include
the extension's build-tree lib directory; the launcher propagates that into the
test process environment.
---
 CMake/SlicerInstallConfig.cmake.in | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/CMake/SlicerInstallConfig.cmake.in b/CMake/SlicerInstallConfig.cmake.in
index 8ccabf931e..59a3bfb662 100644
--- a/CMake/SlicerInstallConfig.cmake.in
+++ b/CMake/SlicerInstallConfig.cmake.in
@@ -190,6 +190,14 @@ endif()
 # Extension build support (required when building extensions against an installed Slicer)
 set(Slicer_EXTENSION_GENERATE_CONFIG "${Slicer_CMAKE_DIR}/SlicerExtensionGenerateConfig.cmake")
 
+# Launch command used by SlicerMacroSimpleTest and SlicerMacroBuildLoadableModule
+# when defining CTest tests.  Replaces the CTK applauncher (absent in Guix):
+# slicer-launch extends LD_LIBRARY_PATH from SLICER_ADDITIONAL_MODULE_PATHS and
+# then execs its arguments, so the developer can point that variable at their
+# extension build directory before running ctest.
+set(Slicer_LAUNCH_COMMAND "${Slicer_HOME}/bin/slicer-launch")
+set(SEM_LAUNCH_COMMAND "${Slicer_HOME}/bin/slicer-launch")
+
 # Components needed to build modules from outside a Slicer build tree or
 # from outside a Slicer installation tree
 # set(TCLAP_DIR "${Slicer_HOME}/lib/tclap")
