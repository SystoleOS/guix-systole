From b5375b85e51444a452d60f6c8f4c493fd33819ac Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 4 Mar 2026 07:06:58 +0100
Subject: [PATCH] COMP: Export Slicer_BUILD_QT_DESIGNER_PLUGINS in install-tree
 SlicerConfig

Expose Slicer_BUILD_QT_DESIGNER_PLUGINS in SlicerInstallConfig.cmake.in
so that standalone module builds (e.g. slicer-segmentations-5.8,
slicer-markups-5.8) inherit the flag via find_package(Slicer).

When the flag is ON the Widgets/DesignerPlugins subdirectory is included,
producing libqSlicerSegmentationsModuleWidgetsPlugins.so and
libqSlicerMarkupsModuleWidgetsPlugins.so in lib/designer/.  Without
them QUiLoader cannot create qMRMLSegmentSelectorWidget,
qSlicerMarkupsPlaceWidget etc. in extension scripted modules.
---
 CMake/SlicerInstallConfig.cmake.in | 1 +
 1 file changed, 1 insertion(+)

diff --git a/CMake/SlicerInstallConfig.cmake.in b/CMake/SlicerInstallConfig.cmake.in
index 92d1ee227c..2c8fba9e5b 100644
--- a/CMake/SlicerInstallConfig.cmake.in
+++ b/CMake/SlicerInstallConfig.cmake.in
@@ -18,6 +18,7 @@ set(Slicer_BUILD_CLI "@Slicer_BUILD_CLI@")
 set(Slicer_BUILD_EXTENSIONMANAGER_SUPPORT "@Slicer_BUILD_EXTENSIONMANAGER_SUPPORT@")
 set(Slicer_BUILD_APPLICATIONUPDATE_SUPPORT "@Slicer_BUILD_APPLICATIONUPDATE_SUPPORT@")
 set(Slicer_BUILD_QTLOADABLEMODULES "@Slicer_BUILD_QTLOADABLEMODULES@")
+set(Slicer_BUILD_QT_DESIGNER_PLUGINS "@Slicer_BUILD_QT_DESIGNER_PLUGINS@")
 
 # Whether Slicer was built with shared libraries.
 set(Slicer_BUILD_SHARED "@BUILD_SHARED_LIBS@")
