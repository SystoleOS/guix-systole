From f4cbaa18757f51d550ca2a9e73f7afd7e012d22d Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 05:54:26 +0200
Subject: [PATCH] COMP: Use lowercase rapidjson target in MRMLCore
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The system RapidJSON CMake config (from Guix) creates an INTERFACE
imported target named "rapidjson" (lowercase).  MRMLCore linked against
the bare name "RapidJSON" (uppercase) which CMake interprets as a
library flag -lRapidJSON — a file that does not exist since RapidJSON is
header-only.  Use the correct target name.
---
 Libs/MRML/Core/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Libs/MRML/Core/CMakeLists.txt b/Libs/MRML/Core/CMakeLists.txt
index 80fdfb3377..dbd4a66126 100644
--- a/Libs/MRML/Core/CMakeLists.txt
+++ b/Libs/MRML/Core/CMakeLists.txt
@@ -359,7 +359,7 @@ set(libs
   ${VTK_LIBRARIES}
   VTK::IOInfovis
   ${LibArchive_LIBRARY}
-  RapidJSON
+  rapidjson
   )
 if(MRML_USE_vtkTeem)
   list(APPEND libs vtkTeem)
-- 
2.52.0

