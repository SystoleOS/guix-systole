From 4372a8a1febf360e8d0b3254b17bd144c99d9ee3 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 21:25:17 +0200
Subject: [PATCH] ENH: Add standalone build support for Texts module (5.10)

- Add cmake_minimum_required/find_package(Slicer) preamble to top-level
- Add LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS} to all macro calls
- Replace _SOURCE_DIR/_BINARY_DIR with _INCLUDE_DIRS in Widgets
- Add MOC_SRCS to ctkMacroBuildQtDesignerPlugin for Q_OBJECT headers
---
 Modules/Loadable/Texts/CMakeLists.txt             | 15 +++++++++++++++
 Modules/Loadable/Texts/Logic/CMakeLists.txt       |  1 +
 .../Texts/SubjectHierarchyPlugins/CMakeLists.txt  |  1 +
 Modules/Loadable/Texts/Widgets/CMakeLists.txt     |  4 ++--
 .../Texts/Widgets/DesignerPlugins/CMakeLists.txt  |  4 ++++
 5 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/Modules/Loadable/Texts/CMakeLists.txt b/Modules/Loadable/Texts/CMakeLists.txt
index ca904dbd5b..28e9e1daac 100644
--- a/Modules/Loadable/Texts/CMakeLists.txt
+++ b/Modules/Loadable/Texts/CMakeLists.txt
@@ -1,9 +1,23 @@
 
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME Texts)
 
 string(TOUPPER ${MODULE_NAME} MODULE_NAME_UPPER)
 
+set(CMAKE_CXX_STANDARD "17")
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR
+    "./share/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR
+    "./lib/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 add_subdirectory(Logic)
 add_subdirectory(Widgets)
@@ -56,5 +70,6 @@ slicerMacroBuildLoadableModule(
   UI_SRCS ${MODULE_UI_SRCS}
   TARGET_LIBRARIES ${MODULE_TARGET_LIBRARIES}
   RESOURCES ${MODULE_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WITH_GENERIC_TESTS
   )
diff --git a/Modules/Loadable/Texts/Logic/CMakeLists.txt b/Modules/Loadable/Texts/Logic/CMakeLists.txt
index 7b9920b176..2cec6152a9 100644
--- a/Modules/Loadable/Texts/Logic/CMakeLists.txt
+++ b/Modules/Loadable/Texts/Logic/CMakeLists.txt
@@ -25,6 +25,7 @@ SlicerMacroBuildModuleLogic(
   INCLUDE_DIRECTORIES ${${KIT}_INCLUDE_DIRECTORIES}
   SRCS ${${KIT}_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   )
 
 # if(BUILD_TESTING)
diff --git a/Modules/Loadable/Texts/SubjectHierarchyPlugins/CMakeLists.txt b/Modules/Loadable/Texts/SubjectHierarchyPlugins/CMakeLists.txt
index 96272d6dc0..5c74d8ac83 100644
--- a/Modules/Loadable/Texts/SubjectHierarchyPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Texts/SubjectHierarchyPlugins/CMakeLists.txt
@@ -44,5 +44,6 @@ SlicerMacroBuildModuleQtLibrary(
   UI_SRCS ${${KIT}_UI_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   RESOURCES ${${KIT}_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WRAP_PYTHONQT
   )
diff --git a/Modules/Loadable/Texts/Widgets/CMakeLists.txt b/Modules/Loadable/Texts/Widgets/CMakeLists.txt
index a003292473..f2334067b3 100644
--- a/Modules/Loadable/Texts/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Texts/Widgets/CMakeLists.txt
@@ -5,8 +5,7 @@ set(KIT ${PROJECT_NAME})
 set(${KIT}_EXPORT_DIRECTIVE "Q_SLICER_MODULE_${MODULE_NAME_UPPER}_WIDGETS_EXPORT")
 
 set(${KIT}_INCLUDE_DIRECTORIES
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_SOURCE_DIR}
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_BINARY_DIR}
+  ${vtkSlicer${MODULE_NAME}ModuleLogic_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
@@ -22,6 +21,7 @@ set(${KIT}_RESOURCES
   )
 
 set(${KIT}_TARGET_LIBRARIES
+  MRMLCore
   )
 
 #-----------------------------------------------------------------------------
diff --git a/Modules/Loadable/Texts/Widgets/DesignerPlugins/CMakeLists.txt b/Modules/Loadable/Texts/Widgets/DesignerPlugins/CMakeLists.txt
index bc9fdc3a5d..3fa62b90c6 100644
--- a/Modules/Loadable/Texts/Widgets/DesignerPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Texts/Widgets/DesignerPlugins/CMakeLists.txt
@@ -23,5 +23,9 @@ ctkMacroBuildQtDesignerPlugin(
   EXPORT_DIRECTIVE ${${KIT}_EXPORT}
   FOLDER "Module-${MODULE_NAME}"
   SRCS ${${KIT}_SRCS}
+  MOC_SRCS
+    qSlicer${MODULE_NAME}ModuleWidgetsAbstractPlugin.h
+    qSlicer${MODULE_NAME}ModuleWidgetsPlugin.h
+    qMRMLTextWidgetPlugin.h
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   )
-- 
2.52.0

