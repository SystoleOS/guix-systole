From 3540e04770f2bc23fe592e2c055c3b283ad7ccb7 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 20:27:43 +0200
Subject: [PATCH] COMP: Add Annotations include dir and LINK_DIRECTORIES to
 Markups Logic

vtkSlicerMarkupsLogic.cxx includes vtkMRMLAnnotationFiducialNode.h from
the Annotations MRML library.  Add vtkSlicerAnnotationsModuleMRML_INCLUDE_DIRS
to INCLUDE_DIRECTORIES and forward EXTRA_MODULE_LIB_DIRS via LINK_DIRECTORIES
so the Annotations library is found at link time in a standalone build.
---
 Modules/Loadable/Markups/Logic/CMakeLists.txt | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/Modules/Loadable/Markups/Logic/CMakeLists.txt b/Modules/Loadable/Markups/Logic/CMakeLists.txt
index f6be59b4e2..2c2e171405 100644
--- a/Modules/Loadable/Markups/Logic/CMakeLists.txt
+++ b/Modules/Loadable/Markups/Logic/CMakeLists.txt
@@ -5,6 +5,7 @@ set(KIT ${PROJECT_NAME})
 set(${KIT}_EXPORT_DIRECTIVE "VTK_SLICER_${MODULE_NAME_UPPER}_MODULE_LOGIC_EXPORT")
 
 set(${KIT}_INCLUDE_DIRECTORIES
+  ${vtkSlicerAnnotationsModuleMRML_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
@@ -25,4 +26,5 @@ SlicerMacroBuildModuleLogic(
   INCLUDE_DIRECTORIES ${${KIT}_INCLUDE_DIRECTORIES}
   SRCS ${${KIT}_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   )
-- 
