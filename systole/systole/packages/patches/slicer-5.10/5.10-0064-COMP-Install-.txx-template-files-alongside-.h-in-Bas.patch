From 8eb6c8763998eae3502aea6911f726481fc93777 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Tue, 3 Mar 2026 09:23:17 +0100
Subject: [PATCH] COMP: Install .txx template files alongside .h in
 BaseQtLibrary install

qSlicerApplicationHelper.h includes qSlicerApplicationHelper.txx via a
relative #include. The SlicerMacroBuildBaseQtLibrary install glob only
captured *.h, leaving the .txx file uninstalled. Extension builds that
include qSlicerApplicationHelper.h (e.g. via generic CXX module tests)
then fail with "No such file or directory" for the .txx file.

Extend the glob to also capture *.txx so template implementations are
co-installed with their corresponding headers.
---
 CMake/SlicerMacroBuildBaseQtLibrary.cmake | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/CMake/SlicerMacroBuildBaseQtLibrary.cmake b/CMake/SlicerMacroBuildBaseQtLibrary.cmake
index f22f2a4b5d..de49b16e06 100644
--- a/CMake/SlicerMacroBuildBaseQtLibrary.cmake
+++ b/CMake/SlicerMacroBuildBaseQtLibrary.cmake
@@ -250,8 +250,9 @@ macro(SlicerMacroBuildBaseQtLibrary)
   # Install headers
   # --------------------------------------------------------------------------
   if(NOT Slicer_INSTALL_NO_DEVELOPMENT)
-    # Install headers
-    file(GLOB headers "${CMAKE_CURRENT_SOURCE_DIR}/*.h")
+    # Install headers and template implementation files (.txx)
+    file(GLOB headers "${CMAKE_CURRENT_SOURCE_DIR}/*.h"
+                      "${CMAKE_CURRENT_SOURCE_DIR}/*.txx")
     install(FILES
       ${headers}
       ${dynamicHeaders}
-- 
