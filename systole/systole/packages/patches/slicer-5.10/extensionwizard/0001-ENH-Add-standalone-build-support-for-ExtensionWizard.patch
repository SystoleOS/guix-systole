From 41e01ce6b1924d723ad30013e65a3163824757a8 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:39 +0200
Subject: [PATCH] ENH: Add standalone build support for ExtensionWizard
 scripted module 5.10

---
 Modules/Scripted/ExtensionWizard/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/ExtensionWizard/CMakeLists.txt b/Modules/Scripted/ExtensionWizard/CMakeLists.txt
index 692cefd64d..4f3f367ef1 100644
--- a/Modules/Scripted/ExtensionWizard/CMakeLists.txt
+++ b/Modules/Scripted/ExtensionWizard/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(ExtensionWizard)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME ExtensionWizard)
 
-- 
2.52.0

