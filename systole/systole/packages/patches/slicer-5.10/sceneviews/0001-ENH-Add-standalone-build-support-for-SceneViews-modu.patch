From 32f0429562443215c4d37111032e8a9ac149fd14 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 21:15:57 +0200
Subject: [PATCH] ENH: Add standalone build support for SceneViews module
 (5.10)

Add cmake_minimum_required/find_package(Slicer) preamble and
LINK_DIRECTORIES for cross-module library lookup.
---
 Modules/Loadable/SceneViews/CMakeLists.txt | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/Modules/Loadable/SceneViews/CMakeLists.txt b/Modules/Loadable/SceneViews/CMakeLists.txt
index 98302646c1..7c76eee5e8 100644
--- a/Modules/Loadable/SceneViews/CMakeLists.txt
+++ b/Modules/Loadable/SceneViews/CMakeLists.txt
@@ -1,9 +1,23 @@
 
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+
 #-----------------------------------------------------------------------
 set(MODULE_NAME SceneViews)
 
 string(TOUPPER ${MODULE_NAME} MODULE_NAME_UPPER)
 
+set(CMAKE_CXX_STANDARD "17")
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR
+    "./share/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR
+    "./lib/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 add_subdirectory(Logic)
 
@@ -62,6 +76,7 @@ slicerMacroBuildLoadableModule(
   UI_SRCS ${MODULE_UI_SRCS}
   TARGET_LIBRARIES ${MODULE_TARGET_LIBRARIES}
   RESOURCES ${MODULE_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WITH_GENERIC_TESTS
   )
 
-- 
