From 71fd04ea77a17693f8639ef25bae0c51deaebdc0 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:37 +0200
Subject: [PATCH] ENH: Add standalone build support for Endoscopy scripted
 module 5.10

---
 Modules/Scripted/Endoscopy/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/Endoscopy/CMakeLists.txt b/Modules/Scripted/Endoscopy/CMakeLists.txt
index 23033e472d..18f9a37724 100644
--- a/Modules/Scripted/Endoscopy/CMakeLists.txt
+++ b/Modules/Scripted/Endoscopy/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(Endoscopy)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 
 #-----------------------------------------------------------------------------
 set(MODULE_NAME Endoscopy)
-- 
2.52.0

