From 43c1845b7503a98bae53085ab0aef52ad3f827dd Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Tue, 3 Mar 2026 06:01:20 +0100
Subject: [PATCH] COMP: Add -D_STL_RELOPS_H to moc_options for GCC 15
 compatibility

Qt5 5.15.x MOC (built with GCC 14) queries the system compiler for
include paths at invocation time. When the active compiler is GCC 15,
its stl_relops.h contains a deprecated namespace attribute:

  namespace rel_ops _GLIBCXX20_DEPRECATED_SUGGEST("<=>")

Qt5 MOC cannot parse [[deprecated]] on namespace declarations, causing
a parse error. Passing -D_STL_RELOPS_H suppresses stl_relops.h via its
include guard, preventing MOC from encountering the problematic syntax.
---
 CMake/SlicerMacroBuildApplication.cmake     | 18 ++++++++++++++++++
 CMake/SlicerMacroBuildBaseQtLibrary.cmake   | 20 ++++++++++++++++++++
 CMake/SlicerMacroBuildLoadableModule.cmake  |  9 +++++++++
 CMake/SlicerMacroBuildModuleQtLibrary.cmake | 16 ++++++++++++++++
 4 files changed, 63 insertions(+)

diff --git a/CMake/SlicerMacroBuildApplication.cmake b/CMake/SlicerMacroBuildApplication.cmake
index d6a28757b1..5190b64622 100644
--- a/CMake/SlicerMacroBuildApplication.cmake
+++ b/CMake/SlicerMacroBuildApplication.cmake
@@ -139,6 +139,24 @@ macro(slicerMacroBuildAppLibrary)
   set(dynamicHeaders
     "${dynamicHeaders};${CMAKE_CURRENT_BINARY_DIR}/${MY_EXPORT_HEADER_PREFIX}Export.h")
 
+  #-----------------------------------------------------------------------------
+  # Sources
+  # --------------------------------------------------------------------------
+    set(_moc_options OPTIONS -DSlicer_HAVE_QT5 -D_STL_RELOPS_H)
+    QT5_WRAP_CPP(SLICERAPPLIB_MOC_OUTPUT ${SLICERAPPLIB_MOC_SRCS} ${_moc_options})
+    QT5_WRAP_UI(SLICERAPPLIB_UI_CXX ${SLICERAPPLIB_UI_SRCS})
+    if(DEFINED SLICERAPPLIB_RESOURCES)
+      QT5_ADD_RESOURCES(SLICERAPPLIB_QRC_SRCS ${SLICERAPPLIB_RESOURCES})
+    endif()
+
+  set_source_files_properties(
+    ${SLICERAPPLIB_UI_CXX}
+    ${SLICERAPPLIB_MOC_OUTPUT}
+    ${SLICERAPPLIB_QRC_SRCS}
+    WRAP_EXCLUDE
+    )
+
+
   # --------------------------------------------------------------------------
   # Source groups
   # --------------------------------------------------------------------------
diff --git a/CMake/SlicerMacroBuildBaseQtLibrary.cmake b/CMake/SlicerMacroBuildBaseQtLibrary.cmake
index f22f2a4b5d..32ee1e7a5d 100644
--- a/CMake/SlicerMacroBuildBaseQtLibrary.cmake
+++ b/CMake/SlicerMacroBuildBaseQtLibrary.cmake
@@ -154,6 +154,26 @@ macro(SlicerMacroBuildBaseQtLibrary)
   set(dynamicHeaders
     "${dynamicHeaders};${CMAKE_CURRENT_BINARY_DIR}/${MY_EXPORT_HEADER_PREFIX}Export.h")
 
+  #-----------------------------------------------------------------------------
+  # Sources
+  # --------------------------------------------------------------------------
+    set(_moc_options OPTIONS -DSlicer_HAVE_QT5 -D_STL_RELOPS_H)
+    QT5_WRAP_CPP(SLICERQTBASELIB_MOC_OUTPUT ${SLICERQTBASELIB_MOC_SRCS} ${_moc_options})
+    QT5_WRAP_UI(SLICERQTBASELIB_UI_CXX ${SLICERQTBASELIB_UI_SRCS})
+    if(DEFINED SLICERQTBASELIB_RESOURCES)
+      QT5_ADD_RESOURCES(SLICERQTBASELIB_QRC_SRCS ${SLICERQTBASELIB_RESOURCES})
+    endif()
+
+    QT5_ADD_RESOURCES(SLICERQTBASELIB_QRC_SRCS ${Slicer_SOURCE_DIR}/Resources/qSlicer.qrc)
+
+  set_source_files_properties(
+    ${SLICERQTBASELIB_UI_CXX}
+    ${SLICERQTBASELIB_MOC_OUTPUT}
+    ${SLICERQTBASELIB_QRC_SRCS}
+    WRAP_EXCLUDE
+    )
+
+
   # --------------------------------------------------------------------------
   # Source groups
   # --------------------------------------------------------------------------
diff --git a/CMake/SlicerMacroBuildLoadableModule.cmake b/CMake/SlicerMacroBuildLoadableModule.cmake
index 21a82131d0..9db42dd63b 100644
--- a/CMake/SlicerMacroBuildLoadableModule.cmake
+++ b/CMake/SlicerMacroBuildLoadableModule.cmake
@@ -163,6 +163,15 @@ macro(slicerMacroBuildLoadableModule)
     message("Warning, Slicer_LOGOS_RESOURCE doesn't exist: ${Slicer_LOGOS_RESOURCE}")
   endif()
 
+    set(_moc_options OPTIONS -DSlicer_HAVE_QT5 -D_STL_RELOPS_H)
+    QT5_WRAP_CPP(LOADABLEMODULE_MOC_OUTPUT ${LOADABLEMODULE_MOC_SRCS} ${_moc_options})
+    QT5_WRAP_UI(LOADABLEMODULE_UI_CXX ${LOADABLEMODULE_UI_SRCS})
+    if(DEFINED LOADABLEMODULE_RESOURCES)
+      QT5_ADD_RESOURCES(LOADABLEMODULE_QRC_SRCS ${LOADABLEMODULE_RESOURCES})
+    endif()
+    QT5_ADD_RESOURCES(LOADABLEMODULE_QRC_SRCS ${Slicer_LOGOS_RESOURCE})
+
+
   set_source_files_properties(
     ${LOADABLEMODULE_SRCS} # For now, let's prevent the module widget from being wrapped
     WRAP_EXCLUDE
diff --git a/CMake/SlicerMacroBuildModuleQtLibrary.cmake b/CMake/SlicerMacroBuildModuleQtLibrary.cmake
index 37d66af65c..8f2e7a7e73 100644
--- a/CMake/SlicerMacroBuildModuleQtLibrary.cmake
+++ b/CMake/SlicerMacroBuildModuleQtLibrary.cmake
@@ -205,6 +205,22 @@ macro(SlicerMacroBuildModuleQtLibrary)
     message("Warning, Slicer_LOGOS_RESOURCE doesn't exist: ${Slicer_LOGOS_RESOURCE}")
   endif()
 
+    set(_moc_options OPTIONS -DSlicer_HAVE_QT5 -D_STL_RELOPS_H)
+    QT5_WRAP_CPP(MODULEQTLIBRARY_MOC_OUTPUT ${MODULEQTLIBRARY_MOC_SRCS} ${_moc_options})
+    QT5_WRAP_UI(MODULEQTLIBRARY_UI_CXX ${MODULEQTLIBRARY_UI_SRCS})
+    if(DEFINED MODULEQTLIBRARY_RESOURCES AND NOT MODULEQTLIBRARY_RESOURCES STREQUAL "")
+      QT5_ADD_RESOURCES(MODULEQTLIBRARY_QRC_SRCS ${MODULEQTLIBRARY_RESOURCES})
+    endif()
+    QT5_ADD_RESOURCES(MODULEQTLIBRARY_QRC_SRCS ${Slicer_LOGOS_RESOURCE})
+
+  set_source_files_properties(
+    ${MODULEQTLIBRARY_UI_CXX}
+    ${MODULEQTLIBRARY_MOC_OUTPUT}
+    ${MODULEQTLIBRARY_QRC_SRCS}
+    WRAP_EXCLUDE
+    )
+
+
   # --------------------------------------------------------------------------
   # Source groups
   # --------------------------------------------------------------------------
