From 4766031c6d0e337afb8c041614a94ebef2cf5381 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 18:45:28 +0200
Subject: [PATCH] COMP: Add qMRMLWidgets to standalone loadable module link
 deps

---
 CMake/SlicerMacroBuildLoadableModule.cmake | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/CMake/SlicerMacroBuildLoadableModule.cmake b/CMake/SlicerMacroBuildLoadableModule.cmake
index 76162666a1..304c9913fd 100644
--- a/CMake/SlicerMacroBuildLoadableModule.cmake
+++ b/CMake/SlicerMacroBuildLoadableModule.cmake
@@ -250,7 +250,10 @@ macro(slicerMacroBuildLoadableModule)
   if(Slicer_GUI_LIBRARY)
     set(_slicer_gui_lib ${Slicer_GUI_LIBRARY})
   else()
-    set(_slicer_gui_lib qSlicerBaseQTCore qSlicerBaseQTGUI)
+    # qMRMLWidgets must also be listed explicitly: qMRMLNodeComboBox and other
+    # symbols are not resolved transitively through qSlicerBaseQTGUI with
+    # --as-needed active.
+    set(_slicer_gui_lib qSlicerBaseQTCore qSlicerBaseQTGUI qMRMLWidgets)
   endif()
 
   # Loadable modules are Qt-based and always need Qt5::Widgets, Qt5::Xml, and
-- 
2.52.0

