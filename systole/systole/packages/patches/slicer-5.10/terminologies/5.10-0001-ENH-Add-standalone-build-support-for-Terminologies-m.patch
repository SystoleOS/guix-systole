From 2d0cd51e18f3e6cca60acbd1b73e2040dc127558 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 16:51:15 +0200
Subject: [PATCH] ENH: Add standalone build support for Terminologies module
 (5.10)

---
 Modules/Loadable/Terminologies/CMakeLists.txt        | 12 ++++++++++++
 Modules/Loadable/Terminologies/Logic/CMakeLists.txt  |  4 +++-
 .../Loadable/Terminologies/Widgets/CMakeLists.txt    |  3 +++
 .../Widgets/DesignerPlugins/CMakeLists.txt           |  8 ++++++--
 4 files changed, 24 insertions(+), 3 deletions(-)

diff --git a/Modules/Loadable/Terminologies/CMakeLists.txt b/Modules/Loadable/Terminologies/CMakeLists.txt
index 44fbea3497..14144f88e8 100644
--- a/Modules/Loadable/Terminologies/CMakeLists.txt
+++ b/Modules/Loadable/Terminologies/CMakeLists.txt
@@ -1,3 +1,15 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(Terminologies)
+set(CMAKE_CXX_STANDARD "17")
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR "./share/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR "./lib/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME "Terminologies")
 
diff --git a/Modules/Loadable/Terminologies/Logic/CMakeLists.txt b/Modules/Loadable/Terminologies/Logic/CMakeLists.txt
index 752f4ad2f2..19e8d383b2 100644
--- a/Modules/Loadable/Terminologies/Logic/CMakeLists.txt
+++ b/Modules/Loadable/Terminologies/Logic/CMakeLists.txt
@@ -7,6 +7,7 @@ find_package(RapidJSON REQUIRED)
 set(${KIT}_EXPORT_DIRECTIVE "VTK_SLICER_${MODULE_NAME_UPPER}_LOGIC_EXPORT")
 
 set(${KIT}_INCLUDE_DIRECTORIES
+  ${RapidJSON_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
@@ -21,7 +22,8 @@ set(${KIT}_SRCS
   )
 
 set(${KIT}_TARGET_LIBRARIES
-  RapidJSON
+  VTK::CommonCore
+  vtkSegmentationCore
   )
 
 #-----------------------------------------------------------------------------
diff --git a/Modules/Loadable/Terminologies/Widgets/CMakeLists.txt b/Modules/Loadable/Terminologies/Widgets/CMakeLists.txt
index 515165035b..2efee30f53 100644
--- a/Modules/Loadable/Terminologies/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Terminologies/Widgets/CMakeLists.txt
@@ -31,6 +31,9 @@ set(${KIT}_RESOURCES
 
 set(${KIT}_TARGET_LIBRARIES
   vtkSlicerTerminologiesModuleLogic
+  CTKWidgets
+  qSlicerBaseQTCore
+  qMRMLWidgets
   )
 
 #-----------------------------------------------------------------------------
diff --git a/Modules/Loadable/Terminologies/Widgets/DesignerPlugins/CMakeLists.txt b/Modules/Loadable/Terminologies/Widgets/DesignerPlugins/CMakeLists.txt
index 82ecad2bed..62a1e24e01 100644
--- a/Modules/Loadable/Terminologies/Widgets/DesignerPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Terminologies/Widgets/DesignerPlugins/CMakeLists.txt
@@ -4,10 +4,13 @@ set(${KIT}_EXPORT "Q_SLICER_MODULE_${MODULE_NAME_UPPER}_WIDGETS_PLUGINS_EXPORT")
 
 set(${KIT}_SRCS
   qSlicerTerminologiesModuleWidgetsAbstractPlugin.cxx
-  qSlicerTerminologiesModuleWidgetsAbstractPlugin.h
   qSlicerTerminologiesModuleWidgetsPlugin.cxx
-  qSlicerTerminologiesModuleWidgetsPlugin.h
   qSlicerTerminologyNavigatorWidgetPlugin.cxx
+  )
+
+set(${KIT}_MOC_SRCS
+  qSlicerTerminologiesModuleWidgetsAbstractPlugin.h
+  qSlicerTerminologiesModuleWidgetsPlugin.h
   qSlicerTerminologyNavigatorWidgetPlugin.h
   )
 
@@ -21,5 +24,6 @@ ctkMacroBuildQtDesignerPlugin(
   EXPORT_DIRECTIVE ${${KIT}_EXPORT}
   FOLDER "Module-${MODULE_NAME}"
   SRCS ${${KIT}_SRCS}
+  MOC_SRCS ${${KIT}_MOC_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   )
-- 
2.52.0

