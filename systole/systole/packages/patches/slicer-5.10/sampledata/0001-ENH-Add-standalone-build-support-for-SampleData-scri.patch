From b0a8025a4d10d4e212a1df2c5ae3fe614f4f291a Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:37 +0200
Subject: [PATCH] ENH: Add standalone build support for SampleData scripted
 module 5.10

---
 Modules/Scripted/SampleData/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/SampleData/CMakeLists.txt b/Modules/Scripted/SampleData/CMakeLists.txt
index d839c7d7f1..03a08ec154 100644
--- a/Modules/Scripted/SampleData/CMakeLists.txt
+++ b/Modules/Scripted/SampleData/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(SampleData)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 
 #-----------------------------------------------------------------------------
 set(MODULE_NAME SampleData)
-- 
2.52.0

