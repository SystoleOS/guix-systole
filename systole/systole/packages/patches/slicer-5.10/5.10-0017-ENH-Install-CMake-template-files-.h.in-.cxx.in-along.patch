From 1fda0dfb62304593d7e9d568d650b6e897c48b3f Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Fri, 20 Feb 2026 21:47:58 +0100
Subject: [PATCH] ENH: Install CMake template files (.h.in, .cxx.in) alongside
 cmake modules

vtkSlicerObjectFactory.h.in and vtkSlicerObjectFactory.cxx.in are
required by SlicerConfigureDisplayableManagerObjectFactory.cmake when
building standalone loadable modules (e.g. Colors) that include a
displayable manager component.  The previous glob only captured *.cmake
files so these templates were missing from the install tree.
---
 CMakeLists.txt | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1a64f12421..704583755d 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1374,7 +1374,10 @@ endif()
 #-----------------------------------------------------------------------------
 if(NOT Slicer_INSTALL_NO_DEVELOPMENT)
 
-  file(GLOB cmake_files "${CMAKE_CURRENT_SOURCE_DIR}/CMake/*.cmake")
+  file(GLOB cmake_files
+    "${CMAKE_CURRENT_SOURCE_DIR}/CMake/*.cmake"
+    "${CMAKE_CURRENT_SOURCE_DIR}/CMake/*.h.in"
+    "${CMAKE_CURRENT_SOURCE_DIR}/CMake/*.cxx.in")
   install(
     FILES ${cmake_files}
     DESTINATION ${Slicer_INSTALL_LIB_DIR}/CMake COMPONENT Development
-- 
