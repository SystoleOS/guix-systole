From f658bf85a65e0f68185ecfc205715ac911c25c6f Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 11:52:51 +0200
Subject: [PATCH] COMP: Guard ui_qSlicerWebWidget.h install on WEBENGINE
 support

---
 Base/QTGUI/CMakeLists.txt | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/Base/QTGUI/CMakeLists.txt b/Base/QTGUI/CMakeLists.txt
index 79b3aedf79..9b4cde515a 100644
--- a/Base/QTGUI/CMakeLists.txt
+++ b/Base/QTGUI/CMakeLists.txt
@@ -275,7 +275,6 @@ if(NOT DEFINED ${PROJECT_NAME}_INSTALL_NO_DEVELOPMENT)
 endif()
 if(NOT ${PROJECT_NAME}_INSTALL_NO_DEVELOPMENT)
   set(ui_headers
-    "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerWebWidget.h"
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerSettingsViewsPanel.h"
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerSettingsUserInformationPanel.h"
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerSettingsStylesPanel.h"
@@ -293,6 +292,10 @@ if(NOT ${PROJECT_NAME}_INSTALL_NO_DEVELOPMENT)
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerDataDialog.h"
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerActionsDialog.h"
     "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerNodeWriterOptionsWidget.h")
+  if(Slicer_BUILD_WEBENGINE_SUPPORT)
+    list(APPEND ui_headers
+      "${CMAKE_CURRENT_BINARY_DIR}/qSlicerBaseQTGUI_autogen/include/ui_qSlicerWebWidget.h")
+  endif()
   install(
     FILES ${ui_headers}
     DESTINATION ${Slicer_INSTALL_INCLUDE_DIR}/${PROJECT_NAME} COMPONENT Development)
-- 
2.52.0

