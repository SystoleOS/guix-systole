From b02ee81cb68ee6c3c4227f12d6844347e711986a Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:38 +0200
Subject: [PATCH] ENH: Add standalone build support for VectorToScalarVolume
 scripted module 5.10

---
 .../VectorToScalarVolume/CMakeLists.txt         | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/VectorToScalarVolume/CMakeLists.txt b/Modules/Scripted/VectorToScalarVolume/CMakeLists.txt
index 158c9256ba..215493ba02 100644
--- a/Modules/Scripted/VectorToScalarVolume/CMakeLists.txt
+++ b/Modules/Scripted/VectorToScalarVolume/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(VectorToScalarVolume)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME VectorToScalarVolume)
 
-- 
2.52.0

