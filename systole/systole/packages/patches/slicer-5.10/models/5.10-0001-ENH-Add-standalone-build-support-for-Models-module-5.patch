From f16df65d52c01762a680f0e476a6708aa959963a Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 20:50:46 +0200
Subject: [PATCH] ENH: Add standalone build support for Models module (5.10)

- Add cmake_minimum_required/find_package(Slicer)/include preamble to top-level CMakeLists
- Add LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS} to slicerMacroBuildLoadableModule
- Add vtkSlicerTerminologiesModuleLogic to SHP TARGET_LIBRARIES + LINK_DIRECTORIES
- Add MOC_SRCS to ctkMacroBuildQtDesignerPlugin for Q_OBJECT headers
---
 Modules/Loadable/Models/CMakeLists.txt            | 15 +++++++++++++++
 .../Models/SubjectHierarchyPlugins/CMakeLists.txt |  2 ++
 .../Models/Widgets/DesignerPlugins/CMakeLists.txt |  4 ++++
 3 files changed, 21 insertions(+)

diff --git a/Modules/Loadable/Models/CMakeLists.txt b/Modules/Loadable/Models/CMakeLists.txt
index b661ba133f..1b93e09643 100644
--- a/Modules/Loadable/Models/CMakeLists.txt
+++ b/Modules/Loadable/Models/CMakeLists.txt
@@ -1,9 +1,23 @@
 
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME Models)
 
 string(TOUPPER ${MODULE_NAME} MODULE_NAME_UPPER)
 
+set(CMAKE_CXX_STANDARD "17")
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR
+    "./share/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR
+    "./lib/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 add_subdirectory(Logic)
 add_subdirectory(SubjectHierarchyPlugins)
@@ -65,6 +79,7 @@ slicerMacroBuildLoadableModule(
   UI_SRCS ${MODULE_UI_SRCS}
   TARGET_LIBRARIES ${MODULE_TARGET_LIBRARIES}
   RESOURCES ${MODULE_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WITH_GENERIC_TESTS
   )
 
diff --git a/Modules/Loadable/Models/SubjectHierarchyPlugins/CMakeLists.txt b/Modules/Loadable/Models/SubjectHierarchyPlugins/CMakeLists.txt
index 4ef0a1c03d..ef5315237f 100644
--- a/Modules/Loadable/Models/SubjectHierarchyPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Models/SubjectHierarchyPlugins/CMakeLists.txt
@@ -32,6 +32,7 @@ set(${KIT}_TARGET_LIBRARIES
   qSlicerSubjectHierarchyModuleWidgets
   vtkSlicerSubjectHierarchyModuleLogic
   qSlicerTerminologiesModuleWidgets
+  vtkSlicerTerminologiesModuleLogic
   qMRMLWidgets
   MRMLLogic
   MRMLCore
@@ -47,5 +48,6 @@ SlicerMacroBuildModuleQtLibrary(
   UI_SRCS ${${KIT}_UI_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   RESOURCES ${${KIT}_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WRAP_PYTHONQT
   )
diff --git a/Modules/Loadable/Models/Widgets/DesignerPlugins/CMakeLists.txt b/Modules/Loadable/Models/Widgets/DesignerPlugins/CMakeLists.txt
index 33b113f53e..a73ecb4332 100644
--- a/Modules/Loadable/Models/Widgets/DesignerPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Models/Widgets/DesignerPlugins/CMakeLists.txt
@@ -23,5 +23,9 @@ ctkMacroBuildQtDesignerPlugin(
   EXPORT_DIRECTIVE ${${KIT}_EXPORT}
   FOLDER "Module-${MODULE_NAME}"
   SRCS ${${KIT}_SRCS}
+  MOC_SRCS
+    qSlicer${MODULE_NAME}WidgetsAbstractPlugin.h
+    qSlicer${MODULE_NAME}WidgetsPlugin.h
+    qMRMLModelDisplayNodeWidgetPlugin.h
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   )
-- 
