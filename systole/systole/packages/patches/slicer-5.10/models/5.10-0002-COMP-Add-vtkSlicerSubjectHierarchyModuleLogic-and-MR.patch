From d0f3b9228dde782441a720f5dfdf44f5783a18e8 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 20:54:18 +0200
Subject: [PATCH] COMP: Add vtkSlicerSubjectHierarchyModuleLogic and MRMLCore
 to Models Widgets

Add missing link dependencies to Models Widgets CMakeLists for
vtkMRMLSubjectHierarchyNode and vtkMRMLDisplayableNode symbols.
Also add LINK_DIRECTORIES for cross-module library lookup.
---
 Modules/Loadable/Models/Widgets/CMakeLists.txt | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/Modules/Loadable/Models/Widgets/CMakeLists.txt b/Modules/Loadable/Models/Widgets/CMakeLists.txt
index fd7e9f7e82..7e4e488af7 100644
--- a/Modules/Loadable/Models/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Models/Widgets/CMakeLists.txt
@@ -6,6 +6,7 @@ set(${KIT}_EXPORT_DIRECTIVE "Q_SLICER_QTMODULES_${MODULE_NAME_UPPER}_WIDGETS_EXP
 
 set(${KIT}_INCLUDE_DIRECTORIES
   ${qSlicerSubjectHierarchyModuleWidgets_INCLUDE_DIRS}
+  ${vtkSlicerSubjectHierarchyModuleLogic_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
@@ -22,6 +23,8 @@ set(${KIT}_RESOURCES
 
 set(${KIT}_TARGET_LIBRARIES
   qSlicerSubjectHierarchyModuleWidgets
+  vtkSlicerSubjectHierarchyModuleLogic
+  MRMLCore
   )
 
 #-----------------------------------------------------------------------------
@@ -33,6 +36,7 @@ SlicerMacroBuildModuleWidgets(
   UI_SRCS ${${KIT}_UI_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   RESOURCES ${${KIT}_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WRAP_PYTHONQT
   )
 
