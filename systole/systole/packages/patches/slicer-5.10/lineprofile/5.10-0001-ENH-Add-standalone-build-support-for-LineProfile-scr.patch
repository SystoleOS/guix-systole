From 3c74483cfb79038526b149d47ae9f2dd68cf90ce Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:39 +0200
Subject: [PATCH] ENH: Add standalone build support for LineProfile scripted
 module 5.10

---
 Modules/Scripted/LineProfile/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/LineProfile/CMakeLists.txt b/Modules/Scripted/LineProfile/CMakeLists.txt
index 925e227b86..1da70871de 100644
--- a/Modules/Scripted/LineProfile/CMakeLists.txt
+++ b/Modules/Scripted/LineProfile/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(LineProfile)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME LineProfile)
 
-- 
2.52.0

