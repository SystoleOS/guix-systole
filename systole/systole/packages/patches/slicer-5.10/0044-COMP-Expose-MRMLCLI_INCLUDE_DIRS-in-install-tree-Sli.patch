From bb0c3d5a014308e967a27b8a9d65fa415e6c2d85 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 25 Feb 2026 12:03:59 +0100
Subject: [PATCH] COMP: Expose MRMLCLI_INCLUDE_DIRS in install-tree
 SlicerConfig

---
 CMake/SlicerInstallConfig.cmake.in | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/CMake/SlicerInstallConfig.cmake.in b/CMake/SlicerInstallConfig.cmake.in
index 7568ff320a..f9c5f0ef9d 100644
--- a/CMake/SlicerInstallConfig.cmake.in
+++ b/CMake/SlicerInstallConfig.cmake.in
@@ -130,6 +130,12 @@ set(Slicer_Libs_INCLUDE_DIRS
   "@vtkAddon_INCLUDE_DIRS@"
   )
 
+# MRMLCLI_INCLUDE_DIRS is only present when CLI support is enabled.
+if(Slicer_BUILD_CLI_SUPPORT)
+  set(MRMLCLI_INCLUDE_DIRS "${Slicer_HOME}/include/MRMLCLI"
+    CACHE INTERNAL "MRMLCLI includes" FORCE)
+endif()
+
 # Slicer Base library directories.
 set(Slicer_Base_LIBRARY_DIRS
   "${Slicer_HOME}/@Slicer_INSTALL_LIB_DIR@"
-- 
2.52.0

