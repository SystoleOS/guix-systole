From 1fb2cc623f0bfb6c3d445ba6e07d12d85ade9b7b Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Thu, 9 Apr 2026 09:26:38 +0200
Subject: [PATCH] ENH: Add standalone build support for WebServer scripted
 module 5.10

---
 Modules/Scripted/WebServer/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Modules/Scripted/WebServer/CMakeLists.txt b/Modules/Scripted/WebServer/CMakeLists.txt
index 659898a8d9..4371edc0c6 100644
--- a/Modules/Scripted/WebServer/CMakeLists.txt
+++ b/Modules/Scripted/WebServer/CMakeLists.txt
@@ -1,3 +1,20 @@
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+project(WebServer)
+
+set(CMAKE_CXX_STANDARD "17")
+
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+
+if(NOT Slicer_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+if(NOT Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTSCRIPTEDMODULES_LIB_DIR
+      "lib/Slicer-${Slicer_VERSION}/qt-scripted-modules")
+endif()
+
 
 #-----------------------------------------------------------------------------
 set(MODULE_NAME WebServer)
-- 
2.52.0

