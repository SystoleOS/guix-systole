From aed828f90004f6932f4e5136a22fa1dd7fbdf818 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 20:01:01 +0200
Subject: [PATCH] COMP: Link vtkSlicerTerminologiesModuleLogic in Colors
 Widgets

qSlicerColorTableTerminologyDelegate and qSlicerTerminologyEditorWidget
use vtkSlicerTerminologiesModuleLogic symbols directly; without explicit
linking the symbols are undefined in a standalone module build.
---
 Modules/Loadable/Colors/Widgets/CMakeLists.txt | 1 +
 1 file changed, 1 insertion(+)

diff --git a/Modules/Loadable/Colors/Widgets/CMakeLists.txt b/Modules/Loadable/Colors/Widgets/CMakeLists.txt
index 7079319968..36226181d5 100644
--- a/Modules/Loadable/Colors/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Colors/Widgets/CMakeLists.txt
@@ -43,6 +43,7 @@ set(${KIT}_TARGET_LIBRARIES
   vtkSlicer${MODULE_NAME}ModuleLogic
   vtkSlicer${MODULE_NAME}ModuleMRML
   qSlicerTerminologiesModuleWidgets
+  vtkSlicerTerminologiesModuleLogic
   qMRMLWidgets
   )
 
