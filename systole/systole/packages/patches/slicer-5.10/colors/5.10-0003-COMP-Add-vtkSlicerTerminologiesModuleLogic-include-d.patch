From ab61fc0aa8e64b25df3f840b7eccd42919b4a7d4 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 19:59:18 +0200
Subject: [PATCH] COMP: Add vtkSlicerTerminologiesModuleLogic include dir to
 Colors Widgets

qSlicerTerminologyNavigatorWidget.h (from the Terminologies module
widgets) includes vtkSlicerTerminologyEntry.h which lives in the
Terminologies Logic include directory.  Without this path the compiler
cannot find the header when building Colors as a standalone module.
---
 Modules/Loadable/Colors/Widgets/CMakeLists.txt | 1 +
 1 file changed, 1 insertion(+)

diff --git a/Modules/Loadable/Colors/Widgets/CMakeLists.txt b/Modules/Loadable/Colors/Widgets/CMakeLists.txt
index eb3a918f01..7079319968 100644
--- a/Modules/Loadable/Colors/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Colors/Widgets/CMakeLists.txt
@@ -7,6 +7,7 @@ set(${KIT}_EXPORT_DIRECTIVE "Q_SLICER_MODULE_${MODULE_NAME_UPPER}_WIDGETS_EXPORT
 set(${KIT}_INCLUDE_DIRECTORIES
   ${vtkSlicer${MODULE_NAME}ModuleMRML_INCLUDE_DIRS}
   ${qSlicerTerminologiesModuleWidgets_INCLUDE_DIRS}
+  ${vtkSlicerTerminologiesModuleLogic_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
-- 
