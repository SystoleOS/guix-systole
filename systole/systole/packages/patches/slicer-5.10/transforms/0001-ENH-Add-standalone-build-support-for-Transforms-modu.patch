From 300523d65d6bd0b953352894ce9b77fa926af0ae Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 21:21:44 +0200
Subject: [PATCH] ENH: Add standalone build support for Transforms module
 (5.10)

- Add cmake_minimum_required/find_package(Slicer) preamble to top-level
- Add LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS} to slicerMacroBuildLoadableModule,
  SlicerMacroBuildModuleLogic (Logic), and SlicerMacroBuildModuleQtLibrary (SHP)
- Replace _SOURCE_DIR/_BINARY_DIR with _INCLUDE_DIRS in Widgets
- Add MOC_SRCS to ctkMacroBuildQtDesignerPlugin for Q_OBJECT headers
---
 Modules/Loadable/Transforms/CMakeLists.txt        | 15 +++++++++++++++
 Modules/Loadable/Transforms/Logic/CMakeLists.txt  |  1 +
 .../SubjectHierarchyPlugins/CMakeLists.txt        |  1 +
 .../Loadable/Transforms/Widgets/CMakeLists.txt    |  3 +--
 .../Widgets/DesignerPlugins/CMakeLists.txt        |  5 +++++
 5 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/Modules/Loadable/Transforms/CMakeLists.txt b/Modules/Loadable/Transforms/CMakeLists.txt
index 218fbc9fe7..4d9bf1feb7 100644
--- a/Modules/Loadable/Transforms/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/CMakeLists.txt
@@ -1,9 +1,23 @@
 
+cmake_minimum_required(VERSION 3.16.3...3.19.7 FATAL_ERROR)
+
 #-----------------------------------------------------------------------------
 set(MODULE_NAME Transforms)
 
 string(TOUPPER ${MODULE_NAME} MODULE_NAME_UPPER)
 
+set(CMAKE_CXX_STANDARD "17")
+find_package(Slicer REQUIRED)
+include(${Slicer_USE_FILE})
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_SHARE_DIR
+    "./share/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+if(NOT Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR)
+  set(Slicer_INSTALL_QTLOADABLEMODULES_LIB_DIR
+    "./lib/Slicer-${Slicer_VERSION}/qt-loadable-modules")
+endif()
+
 #-----------------------------------------------------------------------------
 add_subdirectory(Logic)
 add_subdirectory(MRMLDM)
@@ -57,6 +71,7 @@ slicerMacroBuildLoadableModule(
   UI_SRCS ${MODULE_UI_SRCS}
   TARGET_LIBRARIES ${MODULE_TARGET_LIBRARIES}
   RESOURCES ${MODULE_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WITH_GENERIC_TESTS
   )
 
diff --git a/Modules/Loadable/Transforms/Logic/CMakeLists.txt b/Modules/Loadable/Transforms/Logic/CMakeLists.txt
index affa5e4966..b9718da8b6 100644
--- a/Modules/Loadable/Transforms/Logic/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/Logic/CMakeLists.txt
@@ -25,6 +25,7 @@ SlicerMacroBuildModuleLogic(
   INCLUDE_DIRECTORIES ${${KIT}_INCLUDE_DIRECTORIES}
   SRCS ${${KIT}_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   )
 
 if(BUILD_TESTING)
diff --git a/Modules/Loadable/Transforms/SubjectHierarchyPlugins/CMakeLists.txt b/Modules/Loadable/Transforms/SubjectHierarchyPlugins/CMakeLists.txt
index 32edbdc586..793ed820ce 100644
--- a/Modules/Loadable/Transforms/SubjectHierarchyPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/SubjectHierarchyPlugins/CMakeLists.txt
@@ -46,5 +46,6 @@ SlicerMacroBuildModuleQtLibrary(
   UI_SRCS ${${KIT}_UI_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   RESOURCES ${${KIT}_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WRAP_PYTHONQT
   )
diff --git a/Modules/Loadable/Transforms/Widgets/CMakeLists.txt b/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
index 2bde1f7140..712b36fd74 100644
--- a/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
@@ -5,8 +5,7 @@ set(KIT ${PROJECT_NAME})
 set(${KIT}_EXPORT_DIRECTIVE "Q_SLICER_MODULE_${MODULE_NAME_UPPER}_WIDGETS_EXPORT")
 
 set(${KIT}_INCLUDE_DIRECTORIES
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_SOURCE_DIR}
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_BINARY_DIR}
+  ${vtkSlicer${MODULE_NAME}ModuleLogic_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
diff --git a/Modules/Loadable/Transforms/Widgets/DesignerPlugins/CMakeLists.txt b/Modules/Loadable/Transforms/Widgets/DesignerPlugins/CMakeLists.txt
index 33c462b72c..2df8b9fa3a 100644
--- a/Modules/Loadable/Transforms/Widgets/DesignerPlugins/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/Widgets/DesignerPlugins/CMakeLists.txt
@@ -25,5 +25,10 @@ ctkMacroBuildQtDesignerPlugin(
   EXPORT_DIRECTIVE ${${KIT}_EXPORT}
   FOLDER "Module-${MODULE_NAME}"
   SRCS ${${KIT}_SRCS}
+  MOC_SRCS
+    qSlicer${MODULE_NAME}ModuleWidgetsAbstractPlugin.h
+    qSlicer${MODULE_NAME}ModuleWidgetsPlugin.h
+    qMRMLTransformDisplayNodeWidgetPlugin.h
+    qMRMLTransformInfoWidgetPlugin.h
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   )
-- 
2.52.0

