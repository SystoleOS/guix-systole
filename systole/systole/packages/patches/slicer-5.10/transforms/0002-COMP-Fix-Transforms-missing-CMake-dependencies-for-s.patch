From 35859879fe0d2a707d31f0c741935f9217441001 Mon Sep 17 00:00:00 2001
From: Rafael Palomar <rafael.palomar@ous-research.no>
Date: Wed, 8 Apr 2026 21:46:09 +0200
Subject: [PATCH] COMP: Fix Transforms missing CMake dependencies for
 standalone build (5.10)

- Logic: Add ${ITK_INCLUDE_DIRS} and ${ITK_LIBRARIES} for ITK transform headers
- MRMLDM: Replace _SOURCE_DIR/_BINARY_DIR with _INCLUDE_DIRS, add
  vtkSlicerMarkupsModuleMRML include dirs, add LINK_DIRECTORIES
- Widgets: Add MRMLCore to TARGET_LIBRARIES and LINK_DIRECTORIES
---
 Modules/Loadable/Transforms/Logic/CMakeLists.txt   | 2 ++
 Modules/Loadable/Transforms/MRMLDM/CMakeLists.txt  | 7 +++----
 Modules/Loadable/Transforms/Widgets/CMakeLists.txt | 2 ++
 3 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/Modules/Loadable/Transforms/Logic/CMakeLists.txt b/Modules/Loadable/Transforms/Logic/CMakeLists.txt
index b9718da8b6..a52a234e73 100644
--- a/Modules/Loadable/Transforms/Logic/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/Logic/CMakeLists.txt
@@ -6,6 +6,7 @@ set(${KIT}_EXPORT_DIRECTIVE "VTK_SLICER_${MODULE_NAME_UPPER}_MODULE_LOGIC_EXPORT
 
 set(${KIT}_INCLUDE_DIRECTORIES
   ${vtkSlicerMarkupsModuleMRML_INCLUDE_DIRS}
+  ${ITK_INCLUDE_DIRS}
   )
 
 set(${KIT}_SRCS
@@ -16,6 +17,7 @@ set(${KIT}_SRCS
 set(${KIT}_TARGET_LIBRARIES
   MRMLCore
   vtkSlicerMarkupsModuleMRML
+  ${ITK_LIBRARIES}
   )
 
 #-----------------------------------------------------------------------------
diff --git a/Modules/Loadable/Transforms/MRMLDM/CMakeLists.txt b/Modules/Loadable/Transforms/MRMLDM/CMakeLists.txt
index 4e86d93fea..a02290377f 100644
--- a/Modules/Loadable/Transforms/MRMLDM/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/MRMLDM/CMakeLists.txt
@@ -5,10 +5,8 @@ set(KIT ${PROJECT_NAME})
 set(${KIT}_EXPORT_DIRECTIVE "VTK_SLICER_${MODULE_NAME_UPPER}_MODULE_MRMLDISPLAYABLEMANAGER_EXPORT")
 
 set(${KIT}_INCLUDE_DIRECTORIES
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_SOURCE_DIR}
-  ${vtkSlicer${MODULE_NAME}ModuleLogic_BINARY_DIR}
-  ${vtkSlicer${MODULE_NAME}ModuleMRML_SOURCE_DIR}
-  ${vtkSlicer${MODULE_NAME}ModuleMRML_BINARY_DIR}
+  ${vtkSlicer${MODULE_NAME}ModuleLogic_INCLUDE_DIRS}
+  ${vtkSlicerMarkupsModuleMRML_INCLUDE_DIRS}
   ${CMAKE_CURRENT_BINARY_DIR}
   )
 
@@ -45,4 +43,5 @@ SlicerMacroBuildModuleLogic(
   INCLUDE_DIRECTORIES ${${KIT}_INCLUDE_DIRECTORIES}
   SRCS ${${KIT}_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   )
diff --git a/Modules/Loadable/Transforms/Widgets/CMakeLists.txt b/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
index 712b36fd74..bc381d08fd 100644
--- a/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
+++ b/Modules/Loadable/Transforms/Widgets/CMakeLists.txt
@@ -25,6 +25,7 @@ set(${KIT}_RESOURCES
   )
 
 set(${KIT}_TARGET_LIBRARIES
+  MRMLCore
   )
 
 #-----------------------------------------------------------------------------
@@ -36,6 +37,7 @@ SlicerMacroBuildModuleWidgets(
   UI_SRCS ${${KIT}_UI_SRCS}
   TARGET_LIBRARIES ${${KIT}_TARGET_LIBRARIES}
   RESOURCES ${${KIT}_RESOURCES}
+  LINK_DIRECTORIES ${EXTRA_MODULE_LIB_DIRS}
   WRAP_PYTHONQT
   )
 
-- 
2.52.0

