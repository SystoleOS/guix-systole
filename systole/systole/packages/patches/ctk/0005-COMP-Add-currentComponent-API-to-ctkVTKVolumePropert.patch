From: SystoleOS <systole@example.org>
Date: Thu, 10 Apr 2026 00:00:00 +0200
Subject: [PATCH] COMP: Add currentComponent API to ctkVTKVolumePropertyWidget

Add public getter/setter for the CurrentComponent private member,
required by Slicer 5.10's VolumeRendering module.
---
 .../VTK/Widgets/ctkVTKVolumePropertyWidget.cpp | 17 +++++++++++++++++
 .../VTK/Widgets/ctkVTKVolumePropertyWidget.h   |  4 ++++
 2 files changed, 21 insertions(+)

--- a/Libs/Visualization/VTK/Widgets/ctkVTKVolumePropertyWidget.h	1970-01-01 01:00:01.000000000 +0100
+++ b/Libs/Visualization/VTK/Widgets/ctkVTKVolumePropertyWidget.h	2026-04-09 07:03:57.656980722 +0200
@@ -54,6 +54,8 @@
 
   vtkVolumeProperty* volumeProperty()const;
 
+  int currentComponent()const;
+
   bool isThresholdEnabled()const;
 
   bool isThresholdToggleVisible()const;
@@ -80,6 +82,8 @@
 public Q_SLOTS:
   void setVolumeProperty(vtkVolumeProperty* volumeProperty);
 
+  void setCurrentComponent(int component);
+
   /// Move all the control points of the opacity and colors
   /// by a given offset.
   /// \sa vtkControlPoints::movePoints()
--- a/Libs/Visualization/VTK/Widgets/ctkVTKVolumePropertyWidget.cpp	1970-01-01 01:00:01.000000000 +0100
+++ b/Libs/Visualization/VTK/Widgets/ctkVTKVolumePropertyWidget.cpp	2026-04-09 07:03:57.657638409 +0200
@@ -195,6 +195,25 @@
 }
 
 // ----------------------------------------------------------------------------
+int ctkVTKVolumePropertyWidget::currentComponent()const
+{
+  Q_D(const ctkVTKVolumePropertyWidget);
+  return d->CurrentComponent;
+}
+
+// ----------------------------------------------------------------------------
+void ctkVTKVolumePropertyWidget::setCurrentComponent(int component)
+{
+  Q_D(ctkVTKVolumePropertyWidget);
+  if (d->CurrentComponent == component)
+    {
+    return;
+    }
+  d->CurrentComponent = component;
+  this->updateFromVolumeProperty();
+}
+
+// ----------------------------------------------------------------------------
 void ctkVTKVolumePropertyWidget
 ::setVolumeProperty(vtkVolumeProperty* newVolumeProperty)
 {
